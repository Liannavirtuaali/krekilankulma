# Virtuaalitalli — ympäristömuuttujat
# Kopioi tämä tiedostoksi .env ja muuta arvot

# Tietokanta-asetukset (paikallinen kehitys)
DB_HOST=db
DB_NAME=virtuaalitalli
DB_USER=vt_user
DB_PASS=vt_password
DB_ROOT_PASS=root_password

# Tuotantoon (Altervista) — päivitä db.php:hen suoraan
# DB_HOST=localhost
# DB_NAME=Altervistan_DB_nimi
# DB_USER=Altervistan_kayttaja
# DB_PASS=Altervistan_salasana
