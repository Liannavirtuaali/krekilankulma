# Altervista virtuaalitalli — pääkonfiguraatio
Options -Indexes

# Estä suora pääsy src/-kansioon
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Estä suora pääsy src/-kansioon
    RewriteRule ^src/ - [F,L]

    # Sivut ilman .php-päätettä
    RewriteRule ^hevoset/?$ /pages/hevoset.php [L,QSA]
    RewriteRule ^kasvatus/?$ /pages/kasvatus.php [L,QSA]
    RewriteRule ^yhteystiedot/?$ /pages/yhteystiedot.php [L,QSA]

    # Hevosen profiilisivu kauniin URL:n kautta: /pages/horse/slug
    RewriteRule ^pages/horse/([^/]+)/?$ /pages/hevonen.php?slug=$1 [L,QSA]

    # Blogijuttu kauniin URL:n kautta: /pages/ajankohtaista/slug
    RewriteRule ^pages/ajankohtaista/([^/]+)/?$ /pages/postaus.php?slug=$1 [L,QSA]
</IfModule>

# Tietoturva: Estä suora pääsy arkaluonteisiin tiedostoihin
<FilesMatch "^(config|\.env|\.git|\.htaccess|README|package\.json|composer\.json)">
    Deny from all
</FilesMatch>

# PHP-virheiden piilotus tuotannossa (tietoturva)
php_flag display_errors Off
php_flag display_startup_errors Off
php_value log_errors On
