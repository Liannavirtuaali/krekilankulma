# Altervista virtuaalitalli — pääkonfiguraatio
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Estä suora pääsy src/-kansioon
    RewriteRule ^src/ - [F,L]

    # Sivut ilman .php-päätettä
    # Altervistalla sovellus on /demotalli/-alihakemistossa joten absoluuttiset
    # rewrite-kohteet vaativat /demotalli/-etuliitteen. Paikallisella Dockerilla
    # DocRoot on public/ suoraan, joten /pages/... riittää.
    RewriteCond %{HTTP_HOST} altervista\.org$ [NC]
    RewriteRule ^hevoset/?$ /krekilankulma/pages/hevoset.php [L,QSA]
    RewriteRule ^hevoset/?$ /pages/hevoset.php [L,QSA]

    RewriteCond %{HTTP_HOST} altervista\.org$ [NC]
    RewriteRule ^kasvatus/?$ /krekilankulma/pages/kasvatus.php [L,QSA]
    RewriteRule ^kasvatus/?$ /pages/kasvatus.php [L,QSA]

    RewriteCond %{HTTP_HOST} altervista\.org$ [NC]
    RewriteRule ^yhteystiedot/?$ /krekilankulma/pages/yhteystiedot.php [L,QSA]
    RewriteRule ^yhteystiedot/?$ /pages/yhteystiedot.php [L,QSA]

    RewriteCond %{HTTP_HOST} altervista\.org$ [NC]
    RewriteRule ^ajankohtaista/?$ /krekilankulma/pages/ajankohtaista.php [L,QSA]
    RewriteRule ^ajankohtaista/?$ /pages/ajankohtaista.php [L,QSA]

    # Hevosen profiilisivu: /pages/hevonen/slug
    RewriteCond %{HTTP_HOST} altervista\.org$ [NC]
    RewriteRule ^pages/hevonen/([^/]+)/?$ /krekilankulma/pages/hevonen.php?slug=$1 [L,QSA]
    RewriteRule ^pages/hevonen/([^/]+)/?$ /pages/hevonen.php?slug=$1 [L,QSA]

    # Blogijuttu: /pages/ajankohtaista/slug
    RewriteCond %{HTTP_HOST} altervista\.org$ [NC]
    RewriteRule ^pages/ajankohtaista/([^/]+)/?$ /krekilankulma/pages/postaus.php?slug=$1 [L,QSA]
    RewriteRule ^pages/ajankohtaista/([^/]+)/?$ /pages/postaus.php?slug=$1 [L,QSA]

    # Teeman sivut: /pages/{slug} → theme-page.php (catch-all, vain jos tiedostoa ei ole)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{HTTP_HOST} altervista\.org$ [NC]
    RewriteRule ^pages/([a-z0-9\-]+)/?$ /krekilankulman/pages/theme-page.php?page=$1 [L,QSA]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^pages/([a-z0-9\-]+)/?$ /pages/theme-page.php?page=$1 [L,QSA]
</IfModule>

# Tietoturva: Estä suora pääsy arkaluonteisiin tiedostoihin
<FilesMatch "^(config|\.env|\.git|\.htaccess|README|package\.json|composer\.json)">
    Deny from all
</FilesMatch>

# PHP-virheiden piilotus tuotannossa (tietoturva)
php_flag display_errors Off
php_flag display_startup_errors Off
php_value log_errors On
